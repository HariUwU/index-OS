#!/bin/sh
# WILL OF THE CITY :: THE INDEX  —  labwc autostart
LOCKER="$HOME/.config/labwc/index-lock"

# 1) bring the lock up FIRST and WAIT until it's actually drawn
sh "$LOCKER" &
i=0
while [ "$i" -lt 50 ]; do
  pgrep -f 'lock/lock.qml' >/dev/null 2>&1 && break
  sleep 0.1; i=$((i+1))
done
sleep 0.3   # let the lock paint its first frame before anything else draws

# 2) now load wallpaper + bar BEHIND the lock (ready when you unlock)
swaybg -i "$HOME/.config/labwc/wall.png" -m fill &
swayidle -w lock "sh $LOCKER" &
quickshell -p "$HOME/.config/quickshell/shell.qml" &
